{% for item in paths %}
{{ item }}
{% endfor %}

{% for item in manpaths %}
{{ item }}
{% endfor %}

{% for item in exports %}
export {{ item }}
{% endfor %}

bindkey -e
bindkey -s "\C-r" "\C-a hstr -- \C-j"

unsetopt BEEP
setopt AUTO_CD EXTENDED_GLOB NOMATCH NO_CASE_GLOB NOTIFY CORRECT CORRECT_ALL GLOB_DOTS
setopt SHARE_HISTORY APPEND_HISTORY HIST_VERIFY EXTENDED_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST HIST_SAVE_NO_DUPS HIST_IGNORE_DUPS HIST_REDUCE_BLANKS

HISTFILE=~/.zsh_history
HISTSIZE=2000
SAVEHIST=5000

{{ keychain }}
eval $(dircolors ~/.dir_colors)

source ~/.local/share/git/git-prompt.sh

FPATH=/usr/local/share/zsh-completions:"$FPATH"
zstyle ':completion:*' list-suffixes expand prefix suffix
zstyle ':completion:*' matcher-list 'm:{[:lower:][:upper:]}={[:upper:][:lower:]}' 'm:{[:lower:][:upper:]}={[:upper:][:lower:]} l:|=* r:|=*' 'm:{[:lower:][:upper:]}={[:upper:][:lower:]} l:|=* r:|=*' 'm:{[:lower:][:upper:]}={[:upper:][:lower:]} l:|=* r:|=*'
autoload -Uz compinit && compinit

{% for key, value in aliases.items() %}
alias {{ key }}='{{ value }}'
{% endfor %}

{% for key, value in functions.items() %}
function {{ key }}() {
  {{ value | indent( width=2, indentfirst=False) }}
}

{% endfor -%}

function precmd() {
  local ret=$? git_cwd=""
  local reset="%f"
  local blue="%F{33}" \
        cyan="%F{37}" \
        violet="%F{61}" \
        green="%F{64}" \
        magenta="%F{125}" \
        red="%F{160}" \
        orange="%F{166}"

  _CWD="${blue}%1~${reset}" _TIMESTAMP=" ❲${orange}$(date +%b" "%e" "%T)${reset}❳"
  _HOST="" _PYENV="" _GIT_PRE="" _GIT_POST="" _PROMPT=""

  GIT_PS1_SHOWDIRTYSTATE=true
  GIT_PS1_SHOWSTASHSTATE=true
  GIT_PS1_SHOWUNTRACKEDFILES=true
  GIT_PS1_SHOWCOLORHINTS=true
  GIT_PS1_SHOWUPSTREAM="verbose name"

  [[ -n "$SSH_CONNECTION" && -z "$TMUX" ]] && _HOST="${orange}%m${reset}:"
  [[ -n "$VIRTUAL_ENV" ]] && _PYENV=" ❲${cyan}$(basename "$VIRTUAL_ENV")${reset}❳"
  [[ -n "$CONDA_DEFAULT_ENV" ]] && _PYENV=" ❲${cyan}${CONDA_DEFAULT_ENV}${reset}❳"

  case "$ret" in
    0) _PROMPT="%B${green} %# ${reset}%b"   ;;
    1) _PROMPT="%B${red} %# ${reset}%b"     ;;
    *) _PROMPT="%B${magenta} %# ${reset}%b" ;;
  esac

  if git_cwd="$(git rev-parse --show-toplevel 2> /dev/null)"; then
    _GIT_PRE=" ❲${violet}$(basename "$git_cwd")${reset}|"
    _GIT_POST="❳"
  fi

  __git_ps1 "❲${_HOST}${_CWD}❳${_GIT_PRE}" "${_GIT_POST}${_PYENV}${_PROMPT}" "%s"
  RPROMPT="${_TIMESTAMP}"
}

if [[ -n "$SSH_CONNECTION" ]]; then
  if ! tmux has -t main &> /dev/null
  then tmux new -s main
  else tmux attach -t main
  fi
fi

source {{ usr_path }}/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh