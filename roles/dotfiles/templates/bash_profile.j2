{% for item in paths %}
{{ item }}
{% endfor %}

{% for item in manpaths %}
{{ item }}
{% endfor %}

{% for item in exports %}
export {{ item }}
{% endfor %}

if [[ -n "$SSH_CONNECTION" ]]; then
  if ! tmux has -t main &> /dev/null
  then tmux new -s main
  else tmux attach -t main
  fi
fi

source ~/.bashrc