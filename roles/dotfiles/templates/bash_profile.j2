PATH=""
{% for item in paths %}
PATH={{ item }}:"$PATH"
{% endfor %}

MANPATH=""
{% for item in manpaths %}
MANPATH={{ item }}:"$MANPATH"
{% endfor %}

{% for item in exports %}
export {{ item }}
{% endfor %}

if [[ -z "$TMUX" ]]; then
  tmux new -s "$(keepassxc-cli diceware --words 2 | tr ' ' '-')"
fi

source ~/.bashrc