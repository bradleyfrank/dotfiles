[user]
  name = {{ ansible_user_gecos }}
  email = {{ 'bradfrank@fastmail.com' if 'work_only' in ansible_skip_tags else 'bfrank@oreilly.com' }}
[push]
  default = current
[pull]
  rebase = true
[rebase]
  autoStash = true
[core]
  excludesfile = {{ ansible_env.HOME }}/.gitignore
  editor = vim
[alias]
  co = checkout
  graph = log --oneline --decorate --graph --all
  history = log --full-history --
  last = log -1 HEAD --stat
  ll = log --oneline
  s = switch
  sb = status -sb
  search = !git rev-list --all | xargs git grep -F
  unstage = reset HEAD --
[help]
  autocorrect = 20
[pager]
  diff = diff-so-fancy | less --tabs=1,5 -RFX
  show = diff-so-fancy | less --tabs=1,5 -RFX
[credential "https://git-codecommit.us-east-1.amazonaws.com"]
  helper =
  helper = !aws codecommit credential-helper $@
  UseHttpPath = true
