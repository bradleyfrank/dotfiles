#!/usr/bin/env bash

function find_gist() { gh gist list | sed -rn "s/^([0-9a-fA-F]+)\s+$1-$(basename "$2").*/\1/p" ; }
function push() { VISUAL='tee' gh gist edit "$1" < "$2" ; }
function create() { gh gist create --public --desc "$1-$(basename "$2")" "$2" ; }

function main_update_gists() {
  system="$(uname -s | tr '[:upper:]' '[:lower:]')"
  dotfiles=( "$HOME/.zshrc" "$HOME/.tmux.conf" "$HOME/.vimrc" "$HOME/.bashrc")

  for d in "${dotfiles[@]}"; do
    gist_id="$(find_gist "$system" "$d")"
    if [[ -n "$gist_id" ]]; then push "$gist_id" "$d"
    else create "$system" "$d"
    fi
  done
}

main_update_gists
